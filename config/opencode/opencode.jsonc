{
  "$schema": "https://opencode.ai/config.json",
  "model": "lmstudio/glm47",

  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (host)",
      "options": {
        "baseURL": "http://host.docker.internal:1234/v1"
      },
      "models": {
        "glm47": {
          "id": "zai-org/glm-4.7-flash",
          "name": "GLM 4.7 Flash",
          "tools": true
        },
        "qwen3": {
          "id": "qwen/qwen3-coder-next",
          "name": "Qwen 3 Coder Next",
          "tools": true
        }
      }
    }
  },

  // ===============================
  // エージェント分離（重要）
  // ===============================
  "agent": {
    // 設計・要約・相談用
    "chat": {
      "description": "設計・要約・レビュー（GLM）",
      "model": "lmstudio/glm47",
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false,
        "websearch": false,
        "webfetch": false
      }
    },

    // 実装・修正用
    "build": {
      "description": "実装・修正（Qwen Coder）",
      "model": "lmstudio/qwen3",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "websearch": false,
        "webfetch": false
      }
    }
  }
}